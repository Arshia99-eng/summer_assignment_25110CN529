import java.util.*;
class binary
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number to convert");
        int bin=in.nextInt();
        int temp=0;
        double dec=0.0;
        int place=0;
        while(bin!=0)
        {
            temp=bin%10;
            place++;
            bin=bin/10;
            if(temp==1)
            dec=dec+Math.pow(2,place-1);
        }
        System.out.println(dec);
    }
}
