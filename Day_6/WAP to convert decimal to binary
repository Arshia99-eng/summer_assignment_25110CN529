import java.util.*;
class decimal
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number to convert");
        int dec=in.nextInt();
        String bin="";
        while(dec!=0)
        {
            bin=""+dec%2+bin;
            dec=dec/2;
        }
        System.out.println(bin);
    }
}
