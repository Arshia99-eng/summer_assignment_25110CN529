import java.util.*;
class pow
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number");
        int num=in.nextInt();
        System.out.println("enter the power to be raised");
        int pow=in.nextInt();
        int result=1;
        for(int i=1;i<=pow;i++)
        {
            result=result*num;
        }
        System.out.println(num+" raised to the power "+pow+" is equal to "+result);
    }
}
