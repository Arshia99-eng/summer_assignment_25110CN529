import java.util.*;
class charactertriangle
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the height of the pyramid");
        int h=in.nextInt();
        for(int i=0;i<h;i++)
        {
            for(int j=65;j<=65+i;j++)
            {
                System.out.print((char)j+" ");
            }
            System.out.println(" ");
        }
    }
}
