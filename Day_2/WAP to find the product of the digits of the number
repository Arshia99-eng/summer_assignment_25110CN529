import java.util.*;
class numbers
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number");
        int n=in.nextInt();
        int prd=1;
        while(n!=0)
        {
            prd=prd*(n%10);
            n=n/10;
        }
        System.out.println("the product of the digits is "+prd);
    }
}
