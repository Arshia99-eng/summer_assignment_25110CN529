import java.util.*;
class fibonacci
{
    public static int fibonacci(int x)
    {
       if(x==1)
       return 0;
       if(x==2)
       return 1;
       return fibonacci(x-1)+fibonacci(x-2);
    }
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number");
        int n=in.nextInt();
        for(int i=1;i<=n;i++)
        System.out.println(fibonacci(i));
    }
}
