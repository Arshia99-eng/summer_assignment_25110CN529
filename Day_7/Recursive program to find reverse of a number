import java.util.*;
class ReverseNumber {
    static int rev = 0;

   public static int reverse(int n) {
        if (n == 0) 
        return rev;
        rev = rev * 10 + n % 10;
        return reverse(n / 10);
    }

    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int num = in.nextInt();
        System.out.println(reverse(num));
    }
}
