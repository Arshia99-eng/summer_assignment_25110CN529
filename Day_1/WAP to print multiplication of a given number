import java.util.*;
class table
{
    public static void main(String args[])
    {
        Scanner in=new Scanner(System.in);
        System.out.println("enter the number to get the multiplication table");
        int N,i,prd=1;
        N=in.nextInt();
        System.out.println("MULTIPLICATION TABLE");
        for(i=1;i<=10;i++)
        {
            prd=N*i;
            System.out.println(N+"*"+i+"="+prd);
        }
    }
}
